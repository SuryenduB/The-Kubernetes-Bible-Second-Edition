# --- Functions & Aliases ---

function PowerColorLSWithOptions {
    Clear-Host
    if (Get-Command PowerColorLS -ErrorAction SilentlyContinue) {
        PowerColorLS -a -l --show-directory-size
    } else {
        Get-ChildItem
    }
}
Set-Alias -Name pls -Value PowerColorLSWithOptions -Description "Enhanced LS"

